{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tradeforge/shared-types": ["libs/shared-types/src/index.ts"],
      "@tradeforge/shared-utils": ["libs/shared-utils/src/index.ts"],
      "@tradeforge/shared-ui": ["libs/shared-ui/src/index.ts"],
      "@tradeforge/shell-feature-layout": ["libs/shell/shell-feature-layout/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
