{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Node",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@tradeforge/shared-types": ["libs/shared-types/src/index.ts"],
      "@tradeforge/shared-utils": ["libs/shared-utils/src/index.ts"],
      "@tradeforge/shared-ui": ["libs/shared-ui/src/index.ts"],
      "@tradeforge/shared-ui-icons": ["libs/shared-ui-icons/src/index.ts"],
      "@tradeforge/shared-ui-icons/app-icon": [
        "libs/shared-ui-icons/src/lib/app-icon/app-icon.ts"
      ],
      "@tradeforge/shell-feature-layout": [
        "libs/shell/shell-feature-layout/src/index.ts"
      ],
      "@tradeforge/feature-dashboard": [
        "libs/dashboard/feature-dashboard/src/index.ts"
      ],
      "@tradeforge/feature-profile": ["libs/profile/feature-profile/src/index.ts"],
      "shared-ui-icons": ["libs/shared-ui-icons/src/index.ts"],
      "feature-profile": ["libs/profile/feature-profile/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "tmp"]
}
